    "updatedAt": "2026-06-10T19:54:20.744Z",
    "title": "Host a house concert",
    "hero": {
      "type": "lowImpact",
      "richText": {
        "root": {
          "type": "root",
          "children": [
            {
              "type": "heading",
              "children": [
                {
                  "type": "text",
                  "detail": 0,
                  "format": 0,
                  "mode": "normal",
                  "style": "",
                  "text": "Host a house concert",
                  "version": 1
                }
              ],
              "direction": "ltr",
              "format": "",
              "indent": 0,
              "tag": "h1",
              "version": 1
            }
          ],
          "direction": "ltr",
          "format": "",
          "indent": 0,
          "version": 1
        }
      },
      "links": []
    },
    "layout": [
      {
        "blockType": "content",
        "columns": [
          {
            "size": "twoThirds",
            "richText": {
              "root": {
                "type": "root",
                "children": [
                  {
                    "type": "paragraph",
                    "children": [
                      {
                        "type": "text",
                        "detail": 0,
                        "format": 0,
                        "mode": "normal",
                        "style": "",
                        "text": "Some of my favorite shows ever have been in living rooms and backyards. Twenty or thirty people, no stage, no PA half the time — just songs and the people you invited.",
                        "version": 1
                      }
                    ],
                    "direction": "ltr",
                    "format": "",
                    "indent": 0,
                    "textFormat": 0,
                    "version": 1
                  },
                  {
                    "type": "paragraph",
                    "children": [
                      {
                        "type": "text",
                        "detail": 0,
                        "format": 0,
                        "mode": "normal",
                        "style": "",
                        "text": "Here's how it works: you bring the people and the space, I bring the music. You invite your friends and neighbors, and we make an evening of it — we'll figure out what works when we talk.",
                        "version": 1
                      }
                    ],
                    "direction": "ltr",
                    "format": "",
                    "indent": 0,
                    "textFormat": 0,
                    "version": 1
                  },
                  {
                    "type": "paragraph",
                    "children": [
                      {
                        "type": "text",
                        "detail": 0,
                        "format": 0,
                        "mode": "normal",
                        "style": "",
                        "text": "I handle the rest. If you've got a room, a porch, or a backyard in Oregon or anywhere in the Northwest, I'd love to come play it.",
                        "version": 1
                      }
                    ],
                    "direction": "ltr",
                    "format": "",
                    "indent": 0,
                    "textFormat": 0,
                    "version": 1
                  }
                ],
                "direction": "ltr",
                "format": "",
                "indent": 0,
                "version": 1
              }
            },
            "link": {
              "type": "reference",
              "appearance": "default"
            },
            "id": "6a29c0ec1038df37a1fa44e2"
          }
        ],
        "id": "6a29c0ec1038df37a1fa44e3"
      },
      {
        "blockType": "formBlock",
        "form": "6a29c0e9f911f695b52b1f9f",
        "enableIntro": true,
        "introContent": {
          "root": {
            "type": "root",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "detail": 0,
                    "format": 0,
                    "mode": "normal",
                    "style": "",
                    "text": "Tell me roughly where you are and what you're imagining — I read every note.",
                    "version": 1
                  }
                ],
                "direction": "ltr",
                "format": "",
                "indent": 0,
                "textFormat": 0,
                "version": 1
              }
            ],
            "direction": "ltr",
            "format": "",
            "indent": 0,
            "version": 1
          }
        },
        "id": "6a29c0ec1038df37a1fa44e4"
      }
    ],
