                  "text": "TEB",
                  "version": 1
                }
              ],
              "direction": "ltr",
              "format": "",
              "indent": 0,
              "tag": "h1",
              "version": 1
            }
          ],
          "direction": "ltr",
          "format": "",
          "indent": 0,
          "version": 1
        }
      },
      "links": []
    },
    "layout": [
      {
        "blockType": "content",
        "columns": [
          {
            "size": "twoThirds",
            "richText": {
              "root": {
                "type": "root",
                "children": [
                  {
                    "type": "paragraph",
                    "children": [
                      {
                        "type": "text",
                        "detail": 0,
                        "format": 0,
                        "mode": "normal",
                        "style": "",
                        "text": "TEB is what happens when five longtime friends from Bend, Oregon stop rehearsing and start listening to each other. Travis Ehrenstrom writes the songs — folk storytelling at the core — and the band takes them somewhere new every night: funk, jam-rock, and the kind of improvised detours that only come from a decade of playing together.",
                        "version": 1
                      }
                    ],
                    "direction": "ltr",
                    "format": "",
                    "indent": 0,
                    "textFormat": 0,
                    "version": 1
                  },
                  {
                    "type": "paragraph",
                    "children": [
                      {
                        "type": "text",
                        "detail": 0,
                        "format": 0,
                        "mode": "normal",
                        "style": "",
                        "text": "The lineup: Travis Ehrenstrom (vocals, guitar), Patrick Pearsall (bass, vocals), Conner Bennett (lead guitar), Patrick Ondrozeck (keys), and Kyle Pickard (drums).",
                        "version": 1
                      }
                    ],
                    "direction": "ltr",
                    "format": "",
                    "indent": 0,
                    "textFormat": 0,
                    "version": 1
                  },
                  {
                    "type": "paragraph",
                    "children": [
                      {
                        "type": "text",
                        "detail": 0,
                        "format": 0,
                        "mode": "normal",
                        "style": "",
                        "text": "What started as brewery stands around Central Oregon has grown into festival slots at Sisters Folk Festival, 4 Peaks, Cascade Equinox, Bend's Fall Festival, and Cruxapalooza, plus albums including Something on the Surface (2018), Hollinshead (2023), and Lady Luck (2024) — the last one recorded live in a living room to bottle what the band does on stage.",
                        "version": 1
                      }
                    ],
                    "direction": "ltr",
                    "format": "",
                    "indent": 0,
                    "textFormat": 0,
                    "version": 1
                  }
                ],
                "direction": "ltr",
                "format": "",
                "indent": 0,
                "version": 1
              }
            },
            "link": {
              "type": "reference",
              "appearance": "default"
            },
            "id": "6a29c0ec1038df37a1fa44d9"
          }
        ],
        "id": "6a29c0ec1038df37a1fa44da"
      },
      {
        "blockType": "pressQuotes",
        "heading": "",
        "quotes": [
          {
            "quote": "Every time I play with those guys, there's a moment where it's just like — whoa, I can't believe we just did that.",
            "attribution": "Travis Ehrenstrom",
            "source": "That's the show.",
            "id": "6a29c0ec1038df37a1fa44db"
          }
        ],
        "recentPress": [],
        "id": "6a29c0ec1038df37a1fa44dc"
      },
